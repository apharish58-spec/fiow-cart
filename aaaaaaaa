<script>
document.addEventListener('DOMContentLoaded', function() {
    const checkboxes = document.querySelectorAll('.product-checkbox');
    const totalDisplay = document.getElementById('item-total');
    const countDisplay = document.getElementById('item-count');

    function updateCart() {
        let total = 0, count = 0;
        checkboxes.forEach(cb => {
            if (cb.checked) {
                total += parseFloat(cb.getAttribute('data-price')) * parseInt(cb.getAttribute('data-qty'));
                count++;
            }
        });
        totalDisplay.innerText = total.toLocaleString('en-IN');
        countDisplay.innerText = count;
    }

    checkboxes.forEach(cb => cb.addEventListener('change', updateCart));
});
</script>

